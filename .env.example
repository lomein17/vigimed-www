# Feature flag: renders the post-repositioning Home at /{locale}/ when 'true'.
# Any other value (or unset) redirects to the chromeless ComingSoon.
# Vercel scoping: Production='false' (or unset), Staging='true', Development='true'.
# Server-side read; no NEXT_PUBLIC_ prefix, so the value is not inlined into the client bundle.
SHOW_HOME=true
